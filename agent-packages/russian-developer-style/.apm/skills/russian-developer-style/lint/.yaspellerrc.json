{
  "lang": "ru",
  "format": "markdown",
  "fileExtensions": [
    ".md",
    ".markdown"
  ],
  "excludeFiles": [
    "node_modules/**",
    "vendor/**",
    "dist/**",
    "build/**",
    ".git/**",
    "apm_modules/**"
  ],
  "ignoreText": [
    "```[\\s\\S]*?```",
    "`[^`]+`"
  ],
  "ignoreTags": [
    "code",
    "pre",
    "tt",
    "style",
    "script"
  ],
  "ignoreUrls": true,
  "findRepeatWords": true,
  "flagLatin": false,
  "maxRequests": 2,
  "dictionary": [
    "apm",
    "Qubership",
    "Kubernetes",
    "Postgres",
    "PostgreSQL",
    "Kafka",
    "Helm",
    "Quarkus",
    "Fiber",
    "Grafana",
    "Prometheus",
    "Docker",
    "Dockerfile",
    "GitLab",
    "GitHub",
    "OpenAPI",
    "OAuth",
    "JWT",
    "TLS",
    "mTLS",
    "DNS",
    "TCP",
    "UDP",
    "HTTP",
    "HTTPS",
    "URL",
    "URI",
    "JSON",
    "YAML",
    "TOML",
    "Markdown",
    "TypeScript",
    "JavaScript",
    "Golang",
    "Java",
    "Python",
    "Rust",
    "Node",
    "npm",
    "pnpm",
    "yarn",
    "Maven",
    "Gradle",
    "REST",
    "gRPC",
    "GraphQL",
    "CRD",
    "ICU",
    "Fluent",
    "i18n",
    "l10n",
    "SDK",
    "CLI",
    "CI",
    "CD"
  ]
}
