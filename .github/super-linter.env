# Local overrides on top of .github/linters/super-linter.env (from netcracker/.github).
# Loaded by .github/workflows/super-linter.yaml.

# netcracker/.github ships its markdownlint config as `.markdownlint.json`,
# but super-linter v8's default MARKDOWN_CONFIG_FILE is `.markdown-lint.yml`,
# so the file is otherwise ignored and rules like `MD041: false` never apply.
MARKDOWN_CONFIG_FILE=.markdownlint.json
